# --- AWS ---
# SSO profile for dev account 443370708724
AWS_PROFILE=dev

# --- Registry (backend Python/Java) ---
STAGE=dev
# Dev registry API key. Fetch with: aws secretsmanager get-secret-value \
#   --secret-id gnome-registry-api-key-dev --profile dev --query SecretString --output text
GNOME_REGISTRY_API_KEY=

# --- GitHub ---
# Fine-grained PAT with read/write to gnome-trading-group/gnomepy-research
GH_TOKEN=

# --- LLM (at least one required) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Controller API ---
CONTROLLER_API_URL=http://localhost:5050/api
